{
  "name": "fluxionjs-v2",
  "version": "2.0.0",
  "description": "High-performance 2D/3D TypeScript game engine with Electron editor — inspired by Nuake, LumixEngine & s&box",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "node --max-old-space-size=4096 ./node_modules/webpack/bin/webpack.js --config webpack.config.js --env production",
    "build:watch": "node --max-old-space-size=4096 ./node_modules/webpack/bin/webpack.js --config webpack.config.js --watch",
    "start": "npm run build && electron dist/electron/main.js",
    "dev": "concurrently \"npm run build:watch\" \"wait-on dist/electron/main.js && electron dist/electron/main.js\"",
    "lint": "eslint src/ editor/ electron/"
  },
  "keywords": [
    "game-engine",
    "typescript",
    "three.js",
    "electron",
    "ecs",
    "webgpu",
    "pbr",
    "physics"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@dimforge/rapier3d-compat": "^0.14.0",
    "@monaco-editor/react": "^4.7.0",
    "@xyflow/react": "^12.10.1",
    "electron": "^41.0.3",
    "lucide-react": "^1.6.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.170.0",
    "concurrently": "^9.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.0",
    "html-webpack-plugin": "^5.6.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.6.0",
    "wait-on": "^8.0.0",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4"
  }
}
